{
  "$defs": {
    "FileChange": {
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "action": {
          "enum": [
            "created",
            "modified",
            "deleted"
          ],
          "title": "Action",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "path",
        "action",
        "description"
      ],
      "title": "FileChange",
      "type": "object"
    },
    "Status": {
      "enum": [
        "completed",
        "blocked",
        "needs-input"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "properties": {
    "agent": {
      "const": "technical-writer",
      "default": "technical-writer",
      "title": "Agent",
      "type": "string"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/Status"
    },
    "summary": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "artifact_refs": {
      "items": {
        "type": "string"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "decisions": {
      "items": {
        "type": "string"
      },
      "title": "Decisions",
      "type": "array"
    },
    "next_steps": {
      "items": {
        "type": "string"
      },
      "title": "Next Steps",
      "type": "array"
    },
    "token_usage": {
      "default": 0,
      "minimum": 0,
      "title": "Token Usage",
      "type": "integer"
    },
    "files_changed": {
      "items": {
        "$ref": "#/$defs/FileChange"
      },
      "title": "Files Changed",
      "type": "array"
    },
    "style_issues": {
      "items": {
        "type": "string"
      },
      "title": "Style Issues",
      "type": "array"
    }
  },
  "required": [
    "task_id",
    "status",
    "summary"
  ],
  "title": "TechnicalWriterHandoff",
  "type": "object"
}
