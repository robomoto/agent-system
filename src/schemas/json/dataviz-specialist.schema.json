{
  "$defs": {
    "DatavizOption": {
      "properties": {
        "recommendation": {
          "title": "Recommendation",
          "type": "string"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        },
        "precedent": {
          "default": "",
          "title": "Precedent",
          "type": "string"
        },
        "tradeoff": {
          "default": "",
          "title": "Tradeoff",
          "type": "string"
        }
      },
      "required": [
        "recommendation",
        "rationale"
      ],
      "title": "DatavizOption",
      "type": "object"
    },
    "DatavizRecommendation": {
      "properties": {
        "topic": {
          "title": "Topic",
          "type": "string"
        },
        "approach": {
          "default": "conservative",
          "enum": [
            "conservative",
            "exploratory",
            "both"
          ],
          "title": "Approach",
          "type": "string"
        },
        "conservative": {
          "anyOf": [
            {
              "$ref": "#/$defs/DatavizOption"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "exploratory": {
          "anyOf": [
            {
              "$ref": "#/$defs/DatavizOption"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "doc_ref": {
          "default": "",
          "title": "Doc Ref",
          "type": "string"
        }
      },
      "required": [
        "topic"
      ],
      "title": "DatavizRecommendation",
      "type": "object"
    },
    "Status": {
      "enum": [
        "completed",
        "blocked",
        "needs-input"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "properties": {
    "agent": {
      "const": "dataviz-specialist",
      "default": "dataviz-specialist",
      "title": "Agent",
      "type": "string"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/Status"
    },
    "summary": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "artifact_refs": {
      "items": {
        "type": "string"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "decisions": {
      "items": {
        "type": "string"
      },
      "title": "Decisions",
      "type": "array"
    },
    "next_steps": {
      "items": {
        "type": "string"
      },
      "title": "Next Steps",
      "type": "array"
    },
    "token_usage": {
      "default": 0,
      "minimum": 0,
      "title": "Token Usage",
      "type": "integer"
    },
    "domain": {
      "default": "dataviz",
      "title": "Domain",
      "type": "string"
    },
    "recommendations": {
      "items": {
        "$ref": "#/$defs/DatavizRecommendation"
      },
      "title": "Recommendations",
      "type": "array"
    },
    "footguns": {
      "items": {
        "type": "string"
      },
      "title": "Footguns",
      "type": "array"
    }
  },
  "required": [
    "task_id",
    "status",
    "summary"
  ],
  "title": "DatavizSpecialistHandoff",
  "type": "object"
}
