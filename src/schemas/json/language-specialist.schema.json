{
  "$defs": {
    "Recommendation": {
      "properties": {
        "topic": {
          "title": "Topic",
          "type": "string"
        },
        "guidance": {
          "title": "Guidance",
          "type": "string"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        },
        "version": {
          "default": "",
          "title": "Version",
          "type": "string"
        },
        "doc_ref": {
          "default": "",
          "title": "Doc Ref",
          "type": "string"
        }
      },
      "required": [
        "topic",
        "guidance",
        "rationale"
      ],
      "title": "Recommendation",
      "type": "object"
    },
    "Status": {
      "enum": [
        "completed",
        "blocked",
        "needs-input"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "properties": {
    "agent": {
      "pattern": "^[a-z][a-z0-9-]*-specialist$",
      "title": "Agent",
      "type": "string"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/Status"
    },
    "summary": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "artifact_refs": {
      "items": {
        "type": "string"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "decisions": {
      "items": {
        "type": "string"
      },
      "title": "Decisions",
      "type": "array"
    },
    "next_steps": {
      "items": {
        "type": "string"
      },
      "title": "Next Steps",
      "type": "array"
    },
    "token_usage": {
      "default": 0,
      "minimum": 0,
      "title": "Token Usage",
      "type": "integer"
    },
    "domain": {
      "title": "Domain",
      "type": "string"
    },
    "recommendations": {
      "items": {
        "$ref": "#/$defs/Recommendation"
      },
      "title": "Recommendations",
      "type": "array"
    },
    "footguns": {
      "items": {
        "type": "string"
      },
      "title": "Footguns",
      "type": "array"
    }
  },
  "required": [
    "agent",
    "task_id",
    "status",
    "summary",
    "domain"
  ],
  "title": "LanguageSpecialistHandoff",
  "type": "object"
}
