{
  "$defs": {
    "Alert": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "condition": {
          "title": "Condition",
          "type": "string"
        },
        "severity": {
          "enum": [
            "page",
            "ticket"
          ],
          "title": "Severity",
          "type": "string"
        },
        "runbook": {
          "default": "",
          "title": "Runbook",
          "type": "string"
        }
      },
      "required": [
        "name",
        "condition",
        "severity"
      ],
      "title": "Alert",
      "type": "object"
    },
    "FileChange": {
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "action": {
          "enum": [
            "created",
            "modified",
            "deleted"
          ],
          "title": "Action",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "path",
        "action",
        "description"
      ],
      "title": "FileChange",
      "type": "object"
    },
    "SLO": {
      "properties": {
        "metric": {
          "title": "Metric",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "string"
        },
        "measurement": {
          "title": "Measurement",
          "type": "string"
        }
      },
      "required": [
        "metric",
        "target",
        "measurement"
      ],
      "title": "SLO",
      "type": "object"
    },
    "Status": {
      "enum": [
        "completed",
        "blocked",
        "needs-input"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "properties": {
    "agent": {
      "const": "sre",
      "default": "sre",
      "title": "Agent",
      "type": "string"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/Status"
    },
    "summary": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "artifact_refs": {
      "items": {
        "type": "string"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "decisions": {
      "items": {
        "type": "string"
      },
      "title": "Decisions",
      "type": "array"
    },
    "next_steps": {
      "items": {
        "type": "string"
      },
      "title": "Next Steps",
      "type": "array"
    },
    "token_usage": {
      "default": 0,
      "minimum": 0,
      "title": "Token Usage",
      "type": "integer"
    },
    "slos": {
      "items": {
        "$ref": "#/$defs/SLO"
      },
      "title": "Slos",
      "type": "array"
    },
    "alerts": {
      "items": {
        "$ref": "#/$defs/Alert"
      },
      "title": "Alerts",
      "type": "array"
    },
    "monitoring": {
      "items": {
        "type": "string"
      },
      "title": "Monitoring",
      "type": "array"
    },
    "reliability_patterns": {
      "items": {
        "type": "string"
      },
      "title": "Reliability Patterns",
      "type": "array"
    },
    "files_changed": {
      "items": {
        "$ref": "#/$defs/FileChange"
      },
      "title": "Files Changed",
      "type": "array"
    }
  },
  "required": [
    "task_id",
    "status",
    "summary"
  ],
  "title": "SREHandoff",
  "type": "object"
}
