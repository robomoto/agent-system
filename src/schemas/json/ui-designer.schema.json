    "ComponentSpec": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "variants": {
          "items": {
            "type": "string"
          },
          "title": "Variants",
          "type": "array"
        },
        "states": {
          "items": {
            "type": "string"
          },
          "title": "States",
          "type": "array"
        },
        "props": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Props",
          "type": "object"
        },
        "responsive": {
          "default": "",
          "title": "Responsive",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "ComponentSpec",
      "type": "object"
    },
    "FileChange": {
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "action": {
          "enum": [
            "created",
            "modified",
            "deleted"
          ],
          "title": "Action",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "path",
        "action",
        "description"
      ],
      "title": "FileChange",
      "type": "object"
    },
    "Status": {
      "enum": [
        "completed",
        "blocked",
        "needs-input"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "properties": {
    "agent": {
      "const": "ui-designer",
