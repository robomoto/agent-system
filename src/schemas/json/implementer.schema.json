{
  "$defs": {
    "FileChange": {
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "action": {
          "enum": [
            "created",
            "modified",
            "deleted"
          ],
          "title": "Action",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "path",
        "action",
        "description"
      ],
      "title": "FileChange",
      "type": "object"
    },
    "Status": {
      "enum": [
        "completed",
        "blocked",
        "needs-input"
      ],
      "title": "Status",
      "type": "string"
    },
    "TestInfo": {
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "count": {
          "minimum": 0,
          "title": "Count",
          "type": "integer"
        },
        "description": {
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "path",
        "count",
        "description"
      ],
      "title": "TestInfo",
      "type": "object"
    },
    "TestResults": {
      "properties": {
        "passed": {
          "minimum": 0,
          "title": "Passed",
          "type": "integer"
        },
        "failed": {
          "minimum": 0,
          "title": "Failed",
          "type": "integer"
        },
        "skipped": {
          "minimum": 0,
          "title": "Skipped",
          "type": "integer"
        }
      },
      "required": [
        "passed",
        "failed",
        "skipped"
      ],
      "title": "TestResults",
      "type": "object"
    }
  },
  "properties": {
    "agent": {
      "const": "implementer",
      "default": "implementer",
      "title": "Agent",
      "type": "string"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/Status"
    },
    "summary": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "artifact_refs": {
      "items": {
        "type": "string"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "decisions": {
      "items": {
        "type": "string"
      },
      "title": "Decisions",
      "type": "array"
    },
    "next_steps": {
      "items": {
        "type": "string"
      },
      "title": "Next Steps",
      "type": "array"
    },
    "token_usage": {
      "default": 0,
      "minimum": 0,
      "title": "Token Usage",
      "type": "integer"
    },
    "files_changed": {
      "items": {
        "$ref": "#/$defs/FileChange"
      },
      "title": "Files Changed",
      "type": "array"
    },
    "tests_added": {
      "items": {
        "$ref": "#/$defs/TestInfo"
      },
      "title": "Tests Added",
      "type": "array"
    },
    "test_results": {
      "anyOf": [
        {
          "$ref": "#/$defs/TestResults"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "spec_deviations": {
      "items": {
        "type": "string"
      },
      "title": "Spec Deviations",
      "type": "array"
    }
  },
  "required": [
    "task_id",
    "status",
    "summary"
  ],
  "title": "ImplementerHandoff",
  "type": "object"
}
