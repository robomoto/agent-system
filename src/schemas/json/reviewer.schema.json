{
  "$defs": {
    "ReviewFinding": {
      "properties": {
        "severity": {
          "enum": [
            "critical",
            "warning",
            "suggestion"
          ],
          "title": "Severity",
          "type": "string"
        },
        "category": {
          "enum": [
            "security",
            "correctness",
            "performance",
            "maintainability",
            "testing"
          ],
          "title": "Category",
          "type": "string"
        },
        "location": {
          "title": "Location",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "suggested_fix": {
          "title": "Suggested Fix",
          "type": "string"
        },
        "adversarial_note": {
          "default": "",
          "title": "Adversarial Note",
          "type": "string"
        }
      },
      "required": [
        "severity",
        "category",
        "location",
        "description",
        "suggested_fix"
      ],
      "title": "ReviewFinding",
      "type": "object"
    },
    "TestVerification": {
      "properties": {
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "details": {
          "title": "Details",
          "type": "string"
        }
      },
      "required": [
        "passed",
        "details"
      ],
      "title": "TestVerification",
      "type": "object"
    }
  },
  "properties": {
    "agent": {
      "const": "reviewer",
      "default": "reviewer",
      "title": "Agent",
      "type": "string"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "status": {
      "enum": [
        "approved",
        "changes-requested",
        "blocked"
      ],
      "title": "Status",
      "type": "string"
    },
    "summary": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "artifact_refs": {
      "items": {
        "type": "string"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "decisions": {
      "items": {
        "type": "string"
      },
      "title": "Decisions",
      "type": "array"
    },
    "next_steps": {
      "items": {
        "type": "string"
      },
      "title": "Next Steps",
      "type": "array"
    },
    "token_usage": {
      "default": 0,
      "minimum": 0,
      "title": "Token Usage",
      "type": "integer"
    },
    "findings": {
      "items": {
        "$ref": "#/$defs/ReviewFinding"
      },
      "title": "Findings",
      "type": "array"
    },
    "tests_verified": {
      "anyOf": [
        {
          "$ref": "#/$defs/TestVerification"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "task_id",
    "status",
    "summary"
  ],
  "title": "ReviewerHandoff",
  "type": "object"
}
