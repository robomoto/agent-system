{
  "$defs": {
    "DeploymentSpec": {
      "properties": {
        "method": {
          "title": "Method",
          "type": "string"
        },
        "rollback": {
          "title": "Rollback",
          "type": "string"
        },
        "verification": {
          "title": "Verification",
          "type": "string"
        }
      },
      "required": [
        "method",
        "rollback",
        "verification"
      ],
      "title": "DeploymentSpec",
      "type": "object"
    },
    "FileChange": {
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "action": {
          "enum": [
            "created",
            "modified",
            "deleted"
          ],
          "title": "Action",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "path",
        "action",
        "description"
      ],
      "title": "FileChange",
      "type": "object"
    },
    "InfrastructureSpec": {
      "properties": {
        "services_configured": {
          "items": {
            "type": "string"
          },
          "title": "Services Configured",
          "type": "array"
        },
        "networking": {
          "items": {
            "type": "string"
          },
          "title": "Networking",
          "type": "array"
        },
        "secrets": {
          "items": {
            "type": "string"
          },
          "title": "Secrets",
          "type": "array"
        }
      },
      "title": "InfrastructureSpec",
      "type": "object"
    },
    "Status": {
      "enum": [
        "completed",
        "blocked",
        "needs-input"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "properties": {
    "agent": {
      "const": "sysadmin",
      "default": "sysadmin",
      "title": "Agent",
      "type": "string"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/Status"
    },
    "summary": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "artifact_refs": {
      "items": {
        "type": "string"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "decisions": {
      "items": {
        "type": "string"
      },
      "title": "Decisions",
      "type": "array"
    },
    "next_steps": {
      "items": {
        "type": "string"
      },
      "title": "Next Steps",
      "type": "array"
    },
    "token_usage": {
      "default": 0,
      "minimum": 0,
      "title": "Token Usage",
      "type": "integer"
    },
    "infrastructure": {
      "anyOf": [
        {
          "$ref": "#/$defs/InfrastructureSpec"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "deployment": {
      "anyOf": [
        {
          "$ref": "#/$defs/DeploymentSpec"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "files_changed": {
      "items": {
        "$ref": "#/$defs/FileChange"
      },
      "title": "Files Changed",
      "type": "array"
    },
    "runbook_refs": {
      "items": {
        "type": "string"
      },
      "title": "Runbook Refs",
      "type": "array"
    }
  },
  "required": [
    "task_id",
    "status",
    "summary"
  ],
  "title": "SysadminHandoff",
  "type": "object"
}
